# ─────────────────────────────────────────────────────────────────────────────
# LuminaTrace Backend — Environment Variables
#
# LOCAL DEV:  Copy this file to .env and fill in values for Docker Compose.
# PRODUCTION: Set these as environment variables in Render Dashboard.
#             Do NOT commit .env to git — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Application
NODE_ENV=development
PORT=3000
# On Render free tier, PORT must be 10000 — set it in Render env vars.

# ── Database ─────────────────────────────────────────────────────────────────
# LOCAL (Docker Compose):
DB_HOST=localhost
DB_PORT=5433
DB_USER=luminatrace
DB_PASSWORD=luminatrace_password_2026
DB_NAME=luminatrace

# PRODUCTION (Neon.tech — takes priority over individual vars above):
# DATABASE_URL=postgresql://<user>:<password>@<host>.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Pool (Neon-safe defaults — DO NOT raise min above 0 on Neon free tier)
DB_POOL_MAX=5
DB_POOL_MIN=0
DB_POOL_IDLE=5000

# ── Redis ─────────────────────────────────────────────────────────────────────
# LOCAL (Docker Compose):
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# PRODUCTION (Upstash — takes priority over individual vars above):
# REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379
REDIS_URL=

# ── Kafka ─────────────────────────────────────────────────────────────────────
# LOCAL (Docker Compose):
KAFKA_BROKER=localhost:9092
KAFKA_CLIENT_ID=luminatrace-backend
KAFKA_GROUP_ID=luminatrace-consumers

# PRODUCTION (Aiven — set all four):
# KAFKA_BROKER=<service>.aivencloud.com:<port>
# KAFKA_CA_CERT=<full contents of ca.pem — include BEGIN/END headers>
# KAFKA_CLIENT_CERT=<full contents of service.cert>
# KAFKA_CLIENT_KEY=<full contents of service.key>
KAFKA_CA_CERT=
KAFKA_CLIENT_CERT=
KAFKA_CLIENT_KEY=

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d
SESSION_SECRET=dev-session-secret-change-in-production
BCRYPT_ROUNDS=10

# ── CORS ──────────────────────────────────────────────────────────────────────
# LOCAL: comma-separated list
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
CORS_CREDENTIALS=true

# PRODUCTION: your exact Vercel URL — no trailing slash
# CORS_ORIGIN=https://lumina-trace.vercel.app
FRONTEND_URL=http://localhost:5173

# ── Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
RESEND_API_KEY=

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_METRICS=true
ENABLE_TRACING=true
ENABLE_ALERTS=true

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ── Rate Limiting ─────────────────────────────────────────────────────────────
API_RATE_LIMIT=100
API_RATE_LIMIT_WINDOW=900000
